<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/css/output.css" />
    <link rel="icon" type="image/png" href="/title.png" />
    <title>Đăng ký</title>
  </head>
  <body>
    <div class="flex bg-[url('/home.png')] bg-cover bg-fixed h-screen overflow-auto items-center justify-center">
      <div class="border bg-white/10 w-1/4 rounded-4xl p-10 text-white">
        <h1 class="text-3xl font-bold text-center mb-8">Đăng ký</h1>
        <div id="error" class="hidden bg-red-500/20 border border-red-400/50 text-red-300 text-sm text-center rounded-xl px-4 py-2 mb-4"></div>
        <div class="flex flex-col gap-4">
          <input
            id="username"
            type="text"
            placeholder="Tên tài khoản"
            class="bg-blue-300/20 placeholder-white/50 text-white border border-white/20 rounded-2xl px-5 py-3 focus:outline-none focus:border-white/50 transition-all"
          />
          <input
            id="password"
            type="password"
            placeholder="Mật khẩu"
            class="bg-blue-300/20 placeholder-white/50 text-white border border-white/20 rounded-2xl px-5 py-3 focus:outline-none focus:border-white/50 transition-all"
          />
          <input
            id="confirmPassword"
            type="password"
            placeholder="Xác nhận mật khẩu"
            class="bg-blue-300/20 placeholder-white/50 text-white border border-white/20 rounded-2xl px-5 py-3 focus:outline-none focus:border-white/50 transition-all"
          />
          <button onclick="register()" class="bg-blue-300/70 hover:bg-blue-300/90 text-white font-bold rounded-2xl px-5 py-3 transition-all mt-2">Đăng ký</button>
        </div>
        <p class="text-center text-white text-sm mt-6">
          Đã có tài khoản?
          <a href="/" class="text-white hover:underline">Đăng nhập</a>
        </p>
      </div>
    </div>
  </body>
  <script>
    const register = async () => {
      const username = document.getElementById('username').value.trim();
      const password = document.getElementById('password').value;
      const confirmPassword = document.getElementById('confirmPassword').value;
      const error = document.getElementById('error');

      if (!username || !password || !confirmPassword) {
        error.textContent = 'Vui lòng điền đầy đủ thông tin';
        error.classList.remove('hidden');
        return;
      }

      if (password.length < 6) {
        error.textContent = 'Mật khẩu phải ít nhất 6 kí tự';
        error.classList.remove('hidden');
        return;
      }

      if (password !== confirmPassword) {
        error.textContent = 'Mật khẩu xác nhận không khớp';
        error.classList.remove('hidden');
        return;
      }

      const res = await fetch('/register', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ username, password }),
      });

      const data = await res.json();

      if (data.success) {
        window.location.href = data.url;
      } else {
        error.textContent = data.message;
        error.classList.remove('hidden');
      }
    };
  </script>
</html>
