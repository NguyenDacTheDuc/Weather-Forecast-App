<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/css/output.css" />
    <link rel="icon" type="image/png" href="/title.png" />
    <title>Trang chủ</title>
  </head>
  <body>
    <div class="bg-[url('/home.png')] bg-cover bg-fixed  overflow-auto h-screen">
      <div class="flex items-center gap-5 h-full">
        <div class="h-full w-[12%] bg-black/10 text-white font-bold">
        <% if(user) {%>
          <p class="text-xl text-center mt-7 mb-6">Xin chào</p>
          <p class="text-center text-3xl mb-6"><%= user.username %></p>
          <p class="text-sm text-center mt-5 mb-4">Thành phố yêu thích</p>
          <div class="h-2/3 border m-1 rounded-3xl ml-2 overflow-y-auto py-3 px-4">
            <% cities.forEach(city => { %>
              <div class="rounded-2xl hover:border px-2 mb-2 flex justify-between">
                <a href="/search?name=<%=city.name %>" class="flex-1"><%= city.name %></a>
                <button onclick="remove('<%=city.id %>')" class="hover:text-red-400">Xóa</button>
              </div>
            <% }); %>
          </div>
          <button onclick="location.href='/login'" class="ml-2 mt-4 border w-[95%] rounded-lg p-1 hover:bg-red-400 hover:text-black">Đăng xuất</button>
        <% }else{ %>
          <p class="text-3xl text-center mt-20 mb-6">Đăng nhập</p>
          <input type="text" id="username" placeholder="Tên tài khoản" class="ml-2 border rounded-t-lg p-1 w-[95%]" required>
          <input type="password" id="password" placeholder="Mật khẩu" class="ml-2 border rounded-sm my-2 p-1 w-[95%]" required>
          <button onclick="login()" class="ml-2 border w-[95%] rounded-b-lg p-1 hover:bg-green-200 hover:text-black">Đăng nhập</button>
          <p id="error" class="invisible px-2 text-center mt-3 rounded-3xl text-red-500">Test</p> 
          <p class="text-1xl text-center px-2 mt-10 mb-14">( Hãy đăng nhập để có thể sử dụng chức năng lưu địa điểm và xem biểu đồ )</p>
          <a href="/register" class="border rounded-lg ml-2 block text-center w-[93%] text-2xl p-1 hover:bg-red-300 hover:text-black">Đăng ký</a>
        <% } %>
        </div>
        <div class="border bg-white/5 w-[74%] h-[80%] rounded-4xl">
          <form action="/search" method="get" class="bg-blue-300/70 text-black mt-7 flex items-center gap-2 m-auto h-[7%] w-1/2 ps-5 rounded-3xl">
            <input type="text" name="name" placeholder="Tìm kiếm một thành phố..." class="h-full focus:outline-none w-[90%]" required/>
            <button type="submit" class="bg-blue-300 h-[90%] w-[7%] flex justify-center items-center rounded-full">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
            </button>
          </form>
          <p class="text-4xl font-bold text-white text-center mt-7 mb-5">
            <%= data.city.name %>
            <% if (user) { %>
              <button onclick="save('<%= data.city.name %>')" class="text-xl border rounded-2xl py-1 px-3 hover:bg-green-500 relative bottom-1">Lưu</button>
            <% } %>
          </p>
          <p class="text-white text-center"><%= new Date().toLocaleDateString('vi-VN', { 
            weekday: 'long', 
            day: 'numeric', 
            month: 'long',  
            year: 'numeric' 
          }) %></p>
          <div class="mb-4 text-center text-9xl">
              <% if (data.list[0].weather[0].main === 'Clear') { %>
              ☀️  
            <% } else if (data.list[0].weather[0].mainn === 'Clouds') { %>
              ☁️
            <% } else if (data.list[0].weather[0].main === 'Rain') { %>
              🌧️
            <% } else if (data.list[0].weather[0].main === 'Snow') { %>
              ❄️
            <% } else { %>
              🌤️
            <% } %>
            <span id="tempValue" class="text-8xl text-white font-bold cursor-pointer"><%= data.list[0].main.temp  %>°C</span>
          </div>
          <p class="text-center text-4xl font-medium text-white">Trạng thái: <%= data.list[0].weather[0].description %></p>
          <p id="tempFeelValue" class="text-center text-2xl font-medium text-white">Cảm thấy như: <%= Math.round(data.list[0].main.feels_like) %>°C</p>
          <div class="flex justify-center h-[20%] mt-12 gap-12 flex-wrap">
            <div id="wind" class="bg-blue-300/50 text-white font-medium w-60 text-center pt-6 rounded-4xl cursor-pointer">
              <p class="text-2xl">Tốc độ gió</p>
              <p id='windValue' class="text-5xl"><%= data.list[0].wind.speed %> m/s</p>
            </div>
            <div class="bg-blue-300/50 text-white font-medium w-60 text-center pt-6 rounded-4xl">
              <p class="text-2xl">Độ ẩm</p>
              <p class="text-5xl"><%= data.list[0].main.humidity %> %</p>
            </div>
            <div id="visibility" class="bg-blue-300/50 text-white font-medium w-60 text-center pt-6 rounded-4xl cursor-pointer">
              <p class="text-2xl">Tầm nhìn</p>
              <p id="visibilityValue" class="text-5xl"><%= data.list[0].visibility %> m</p>
            </div>
            <div id="pressure" class="bg-blue-300/50 text-white font-medium w-60 text-center pt-6 rounded-4xl cursor-pointer">
              <p class="text-2xl">Áp suất</p>
              <p id="pressureValue" class="text-5xl"><%= data.list[0].main.pressure %> mb</p>
            </div>
          </div>
        </div>
      </div>
      <% if(user){ %>
        <div class="font-bold text-white">
          <p class=" text-3xl text-center mb-5">Thời tiết nhiều ngày</p>
          <div class="flex gap-4 overflow-x-auto justify-around">
            <% for(let i=0, j=0; i<33; i+=8, j+=1){ %>
              <% 
                const temps = data.list.slice(i, i+8).map(d => d.main.temp);
                const midDay = data.list[i+4] || data.list[i];
                const icon = midDay.weather[0].main;
              %>
              <div id="dayWeather" class="cursor-pointer border rounded-3xl py-2 px-3">
                <p class="text-center"><% if(j==0){%>
                  Hôm nay
                <% }else{%>
                  <%=j %> ngày sau
                <% }%></p>
                <div class="flex">
                  <div class="text-5xl">
                    <% if(icon === 'Clear') { %> ☀️
                    <% } else if(icon === 'Clouds') { %> ☁️
                    <% } else if(icon === 'Rain') { %> 🌧️
                    <% } else if(icon === 'Snow') { %> ❄️
                    <% } else { %> 🌤️
                    <% } %>
                  </div>
                  <div>
                    <p>Max: <%= Math.round(Math.max(...temps)) %>°C</p>
                    <p>Min: <%= Math.round(Math.min(...temps)) %>°C</p>
                  </div>
                </div>
              </div>
            <% } %>
          </div>
        </div>
        <div style="position: relative; width: 100%; height: 280px;">
          <canvas id="chart"></canvas>
        </div>
      <% } %>
    </div>
  </body>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
  <script>
    const t= <%= data.list[0].main.temp %>;
    const tF= <%= data.list[0].main.feels_like %>;
    const w= <%= data.list[0].wind.speed %>;
    const v= <%= data.list[0].visibility %>;
    const p= <%= data.list[0].main.pressure %>;
    let isF=false;
    let isKmh=false;
    let isKm=false;
    let isInHg=false;

    const login = async () =>{
      const username=document.getElementById('username').value;
      const password=document.getElementById('password').value;
      const error=document.getElementById('error');

      if(!username || !password){
        error.textContent='Hãy nhập thông tin đầy đủ'
        error.classList.remove('invisible')
        return;
      }

      const res=await fetch('/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ username, password }),
      })

      const data=await res.json();

      if(data.success){
        window.location.href = data.url;
      }else{
        error.textContent = data.message;
        error.classList.remove('invisible');
      }
    }

    document.querySelector('#tempValue').addEventListener('click', (e)=>{
      if (isF) {
        e.currentTarget.textContent=`${t} °C`;
        document.querySelector('#tempFeelValue').textContent=`Cảm thấy như: ${tF} °C`
        isF=false;
      } else {
        const newValuet=(t*1.8+32).toFixed(2);
        const newValuetF=(tF*1.8+32).toFixed(2);
        e.currentTarget.textContent=`${newValuet} °F`;
        document.querySelector('#tempFeelValue').textContent=`Cảm thấy như: ${newValuetF} °F`;
        isF=true;
      }
    })

    document.querySelector('#wind').addEventListener('click', (e)=>{
      if (isKmh) {
        document.querySelector('#windValue').textContent=`${w} m/s`;
        isKmh=false;
      } else {
        const newValue=(w*3.6).toFixed(1);
        document.querySelector('#windValue').textContent=`${newValue} km/h`;
        isKmh=true;
      }
    })
    document.querySelector('#visibility').addEventListener('click', (e)=>{
      if (isKm) {
        document.querySelector('#visibilityValue').textContent=`${v} m`;
        isKm=false;
      } else {
        const newValue=v/1000;
        document.querySelector('#visibilityValue').textContent=`${newValue} km`;
        isKm=true;
      }
    })
    document.querySelector('#pressure').addEventListener('click', (e)=>{
      if (isInHg) {
        document.querySelector('#pressureValue').textContent=`${p} mb`;
        isInHg=false;
      } else {
        const newValue=(p*0.02953).toFixed(1);
        document.querySelector('#pressureValue').textContent=`${newValue} inHg`;
        isInHg=true;
      }
    })

    const save = async (cityName)=>{
      try {
        const res = await fetch('/city', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ 
            name: cityName
          })
        })
        const data = await res.json();
        if (data.success) location.reload();
      } catch (error) {
        console.error(error);
      }
    }

    const remove = async (cityId)=>{
      try {
        const res = await fetch('/city', {
          method: 'DELETE',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ 
            id: cityId
          })
        })
        const data = await res.json();
        if (data.success) location.reload();
      } catch (error) {
        console.error(error);
      }
    }

    const forecast = <%- JSON.stringify(data.list) %>;
    let chart = null;

    const renderChart = (dayIndex) => {
      const dayData = forecast.slice(dayIndex * 8, dayIndex * 8 + 8);
      const labels = dayData.map(item => item.dt_txt.split(' ')[1].slice(0, 5));
      const temps = dayData.map(item => Math.round(item.main.temp));


      if (chart) chart.destroy(); 

      chart = new Chart(document.getElementById('chart'), {
        type: 'line',
        data: {
          labels,
          datasets: [{
            label: 'Nhiệt độ °C',
            data: temps,
            borderColor: '#60a5fa',
            backgroundColor: 'rgba(96, 165, 250, 0.15)',
            fill: true,
            tension: 0.4,
            pointRadius: 4,
            pointBackgroundColor: '#60a5fa',
            borderWidth: 2
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: { legend: { display: false } },
          scales: {
            x: {
              grid: { color: 'rgba(255,255,255,0.05)' },
              ticks: { color: '#94a3b8', font: { size: 12 } }
            },
            y: {
              grid: { color: 'rgba(255,255,255,0.05)' },
              ticks: { color: '#94a3b8', font: { size: 12 }, callback: v => v + '°' }
            }
          }
        }
      });
    };

    renderChart(0);

    document.querySelectorAll('#dayWeather').forEach((el, index) => {
      el.addEventListener('click', () => renderChart(index));
    });
  </script>
</html>
